# ==== Telegram ====
# Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=PUT_YOUR_TOKEN_HERE

# Only these Telegram user ids can use the bot (comma-separated).
# The bot is used in private chats (DMs). Balance notifications are sent
# privately to each of these users. Find a user id with /id or @userinfobot.
AUTHORIZED_USER_IDS=8494222081,7639762965

# ==== SMM Panel ====
# Panel API URL (usually ends with /api/v2)
SMM_API_URL=https://YOUR-PANEL-NAME.com/api/v2
# Panel API key
SMM_API_KEY=PUT_YOUR_API_KEY_HERE

# ==== Balance notifications ====
# Threshold below which the bot warns that the balance is running low (in the panel currency)
BALANCE_LOW_THRESHOLD=5
# How often (in minutes) to check the balance in the background
BALANCE_CHECK_INTERVAL_MIN=30
